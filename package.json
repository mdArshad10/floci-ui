{
  "name": "floci-ui",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/frontend",
    "build": "npm run build --workspace=packages/frontend",
    "dev:api": "cd packages/api && ~/.bun/bin/bun run --watch src/index.ts",
    "start:api": "cd packages/api && ~/.bun/bin/bun run src/index.ts"
  }
}
